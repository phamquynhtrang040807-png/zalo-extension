# Backend
API_TOKEN=change-me-to-a-long-random-token
CORS_ALLOW_ORIGINS=
CORS_ALLOW_ORIGIN_REGEX=^chrome-extension://[a-p]{32}$
DATABASE_URL=sqlite:///./data/auto_zalo.db
# Google Sheets: service_account or oauth
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=Leads
GOOGLE_AUTH_MODE=service_account
GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-service-account.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN_FILE=/run/secrets/google-oauth-token.json
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/v1/integrations/google/callback

# Zalo. Keep DRY_RUN=true until the real API mapping has been verified.
ZALO_ENABLED=true
DRY_RUN=false
ZALO_BASE_URL=http://zalo-bridge:3005
ZALO_TOKEN=change-me-to-a-long-random-bridge-token
ZALO_INVITE_PATH=/friend-request
ZALO_MESSAGE_PATH=/messages
ZALO_RATE_LIMIT_PER_MINUTE=20
ZALO_FORCE_RECIPIENT_ENABLED=false
ZALO_FORCE_RECIPIENT_PHONE=0961382006
ZALO_FRIEND_REQUEST_MESSAGE=Chào bạn, mình là Trang Phạm, đến từ JUSTDUN - brand chuyên về thời trang nữ
ZALO_MESSAGE_TEMPLATE=Chào bạn, mình là Trang Phạm, đến từ JUSTDUN - brand chuyên về thời trang nữ

# Worker
WORKER_POLL_SECONDS=1
MAX_TASK_ATTEMPTS=3
